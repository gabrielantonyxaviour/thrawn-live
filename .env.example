# Thrawn Live — environment template. Copy to .env (gitignored) and fill in.
# PUBLIC REPO: never commit real values. .env / *.key / wallet.json are gitignored.

# ── Network ───────────────────────────────────────────────────────────────
THRAWN_NETWORK=bsc-testnet            # bsc-testnet (free, default) | bsc-mainnet (real funds — live comp only)
BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# ── Agent wallet (TESTNET key — throwaway; never a mainnet key in a public repo) ──
DEPLOYER_PRIVATE_KEY=                 # 0x + 32 bytes; funds DecisionRegistry deploy (testnet tBNB is free)
DECISION_REGISTRY_ADDRESS=            # filled in after deploy

# ── CMC Agent Hub (scored data layer) — NEEDS YOU ────────────────────────────
# Free Basic tier key from https://pro.coinmarketcap.com/account
CMC_PRO_API_KEY=

# ── Trust Wallet Agent Kit (PRIMARY signer) — NEEDS YOU ──────────────────────
# Access ID + HMAC secret from https://portal.trustwallet.com (Agent Wallet mode)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_WALLET_PASSWORD=

# ── Risk config (defaults are sane; override to tune) ────────────────────────
DRAWDOWN_CAP_PCT=30                   # official DQ cap (unpublished; "e.g. 30%")
INTERNAL_HALT_PCT=20                  # our trip-wire — de-risk to stables BELOW the cap
PER_TRADE_RISK_USD=50
MAX_NOTIONAL_USD=500
STARTING_CAPITAL_USD=200
MIN_CONFIDENCE=0.55
